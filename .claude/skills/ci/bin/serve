#!/usr/bin/env bash
# Launch the `ci` runner with process-compose's MCP server over stdio.
# The runner resolves through Nix (no devshell required); MCP clients
# spawn this script as a subprocess and speak JSON-RPC on its
# stdin/stdout. The runner's own logs land in `.ci/pc.log` and per-recipe
# logs go to `.ci/<sha>/<plat>/<recipe>.log` as usual — MCP doesn't
# affect either.
#
# The runner expects to find a `justfile` (or `mod 'ci.just'`) in the
# current working directory with at least one recipe tagged
# `[metadata("ci")]`. See the ci repo README for the recipe-attribute
# vocabulary.
#
# Override knobs (env vars):
#   CI_FLAKE  — flake-ref for the ci runner (default: github:juspay/ci).
#               Set to `path:/abs/path/to/local/ci` for development.
#   CI        — set to `true` to drive strict mode (clean-tree refuse,
#               `git worktree` snapshot of HEAD, commit-status posts).
#               Default unset → local mode (live working tree, no GH
#               posts).

set -euo pipefail

flake="${CI_FLAKE:-github:juspay/ci}"
exec nix run "${flake}" -- run --mcp "$@"
